# ============================================================
# Environment Tracker — Configuration Template
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- LLM Provider ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- INPE Data Endpoints (TerraBrasilis / INPE APIs) ---
# Confirm exact URLs in specs/001-environmental-tracker/research.md (Phase 0)
INPE_DETER_ENDPOINT=https://terrabrasilis.dpi.inpe.br/geoserver/deter-amz/ows
INPE_PRODES_ENDPOINT=https://terrabrasilis.dpi.inpe.br/geoserver/prodes-amz-nb/ows
INPE_FOGO_ENDPOINT=https://terrabrasilis.dpi.inpe.br/queimadas/geoserver/ows

# --- Database ---
# Development default: SQLite (no services needed)
DATABASE_URL=sqlite:///./environment_tracker.db
# Production alternative (Docker Compose path):
# DATABASE_URL=postgresql://envtracker:envtracker@localhost:5432/environment_tracker

# --- Cache ---
# Development default: SQLite-backed cache (REDIS_URL can be empty)
REDIS_URL=
# Production alternative:
# REDIS_URL=redis://localhost:6379/0

# --- Cache Settings ---
CACHE_TTL_DEFAULT=3600

# --- Alert Thresholds ---
ALERT_THRESHOLD_FIRES=100         # hotspots per 24h per region
ALERT_THRESHOLD_DEFORESTATION=50  # % above 12-month average

# --- Langfuse Observability ---
# Get keys at cloud.langfuse.com or your self-hosted instance
LANGFUSE_PUBLIC_KEY=pk-your-public-key
LANGFUSE_SECRET_KEY=sk-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
